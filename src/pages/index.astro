---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContentCard from "../components/ContentCard.astro";
import profile from "../data/profile.json";
import socialLinks from "../data/social-links.json";
import { withBase } from "../lib/paths";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured))
  .slice(0, 4);

const visibleLinks = socialLinks;
---

<BaseLayout>
  <section class="hero-panel border-b border-line">
    <div class="container-page grid min-h-[min(620px,calc(100vh-5rem))] content-center gap-10 py-20 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
      <div class="max-w-4xl">
        <div class="hero-rule"></div>
        <p class="mt-8 text-xs font-semibold uppercase tracking-[0.16em] text-steel">{profile.role}</p>
        <h1 class="mt-5 max-w-3xl text-4xl font-semibold leading-tight text-ink-950 sm:text-5xl lg:text-6xl">
          Data platforms built to be operated, trusted and evolved.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-ink-650">{profile.intro}</p>
        <div class="mt-9 flex flex-wrap gap-3">
          <a class="primary-link" href={withBase("/projects/")}>
            View projects
          </a>
          <a class="secondary-link" href={withBase("/contact/")}>
            Contact
          </a>
          <a class="secondary-link" href={withBase(profile.cvUrl)}>
            CV
          </a>
        </div>
      </div>
      <div class="quiet-card p-6">
        <p class="text-sm font-semibold text-steel">Core focus</p>
        <div class="mt-5 grid gap-4">
          <div class="border-l-2 border-steel pl-4">
            <h2 class="font-semibold text-ink-950">Cloud data platforms</h2>
            <p class="mt-1 text-sm leading-6 text-ink-650">Azure, Databricks, Fabric and Spark delivery.</p>
          </div>
          <div class="border-l-2 border-sage pl-4">
            <h2 class="font-semibold text-ink-950">Architecture that survives operation</h2>
            <p class="mt-1 text-sm leading-6 text-ink-650">Clear layers, security boundaries and maintainable ownership.</p>
          </div>
          <div class="border-l-2 border-sand pl-4">
            <h2 class="font-semibold text-ink-950">Practical AI and agents</h2>
            <p class="mt-1 text-sm leading-6 text-ink-650">RAG, MCP and agent workflows connected to reliable data foundations.</p>
          </div>
        </div>
      </div>
      <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm font-medium text-ink-650 lg:col-span-2">
        <a class="hover:text-ink-950" href={withBase("/writing/")}>Writing</a>
        <a class="hover:text-ink-950" href={withBase("/certifications/")}>Certifications</a>
        {visibleLinks.map((link) => <a class="hover:text-ink-950" href={link.url}>{link.label}</a>)}
      </div>
    </div>
  </section>

  <section class="section-gap soft-band">
    <div class="container-page">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="eyebrow">Selected Work</p>
          <h2 class="mt-3 text-3xl font-semibold text-ink-950">Projects</h2>
        </div>
        <a class="text-sm font-semibold text-ink-950 hover:text-steel" href={withBase("/projects/")}>All projects</a>
      </div>
      <div class="mt-8 grid gap-5 md:grid-cols-2">
        {
          projects.map((project) => (
            <ContentCard
              title={project.data.title}
              description={project.data.description}
              href={withBase(`/projects/${project.id}/`)}
              tags={project.data.tags}
              image={project.data.image}
              imageAlt={project.data.title}
            />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
