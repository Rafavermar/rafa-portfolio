---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContentCard from "../components/ContentCard.astro";
import profile from "../data/profile.json";
import socialLinks from "../data/social-links.json";
import { withBase } from "../lib/paths";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured))
  .slice(0, 4);

const visibleLinks = socialLinks;
---

<BaseLayout>
  <section class="hero-slate relative overflow-hidden border-b border-line">
    <div class="bamboo-panel absolute inset-y-0 right-0 hidden w-[18vw] min-w-48 opacity-90 lg:block"></div>
    <div class="absolute bottom-12 right-[12vw] hidden h-28 w-28 border border-white/20 bg-white/5 lg:block"></div>
    <div class="container-page relative grid min-h-[min(640px,calc(100vh-5rem))] content-center gap-10 py-20">
      <div class="max-w-4xl">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-paper-200">{profile.role}</p>
        <h1 class="mt-5 max-w-3xl text-4xl font-semibold leading-tight text-white sm:text-5xl lg:text-6xl">
          Data platforms built to be operated, trusted and evolved.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-paper-200">{profile.intro}</p>
        <div class="mt-9 flex flex-wrap gap-3">
          <a class="rounded-sm bg-white px-4 py-3 text-sm font-semibold text-ink-950 no-underline transition hover:bg-paper-200" href={withBase("/projects/")}>
            View projects
          </a>
          <a class="rounded-sm border border-white/30 bg-white/10 px-4 py-3 text-sm font-semibold text-white no-underline transition hover:bg-white/15" href={withBase("/contact/")}>
            Contact
          </a>
          <a class="rounded-sm border border-white/30 bg-white/10 px-4 py-3 text-sm font-semibold text-white no-underline transition hover:bg-white/15" href={withBase(profile.cvUrl)}>
            CV
          </a>
        </div>
      </div>
      <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm font-medium text-paper-200">
        <a class="hover:text-white" href={withBase("/writing/")}>Writing</a>
        <a class="hover:text-white" href={withBase("/certifications/")}>Certifications</a>
        {visibleLinks.map((link) => <a class="hover:text-white" href={link.url}>{link.label}</a>)}
      </div>
    </div>
  </section>

  <section class="section-gap">
    <div class="container-page grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="eyebrow">Profile</p>
        <h2 class="mt-3 text-3xl font-semibold text-ink-950">Senior, structured, delivery-focused.</h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {profile.summary.map((paragraph) => <p class="quiet-card p-5 leading-7 text-ink-650">{paragraph}</p>)}
      </div>
    </div>
  </section>

  <section class="section-gap soft-band">
    <div class="container-page">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="eyebrow">Selected Work</p>
          <h2 class="mt-3 text-3xl font-semibold text-ink-950">Projects</h2>
        </div>
        <a class="text-sm font-semibold text-ink-950 hover:text-steel" href={withBase("/projects/")}>All projects</a>
      </div>
      <div class="mt-8 grid gap-5 md:grid-cols-2">
        {
          projects.map((project) => (
            <ContentCard
              title={project.data.title}
              description={project.data.description}
              href={withBase(`/projects/${project.id}/`)}
              tags={project.data.tags}
              image={project.data.image}
              imageAlt={project.data.title}
            />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
