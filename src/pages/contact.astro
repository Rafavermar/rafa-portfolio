---
import BaseLayout from "../layouts/BaseLayout.astro";
import profile from "../data/profile.json";
import socialLinks from "../data/social-links.json";
import { withBase } from "../lib/paths";
import { iconPaths } from "../lib/icons";

const links = socialLinks;
---

<BaseLayout title={`Contact - ${profile.name}`} description="Contact links for Rafael Vera.">
  <section class="section-gap">
    <div class="container-page">
      <h1 class="text-3xl font-semibold tracking-normal text-ink-950 sm:text-4xl">Contact</h1>
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        <section class="quiet-card p-6">
          <h2 class="text-xl font-semibold text-ink-950">Contact channels</h2>
          <div class="mt-5 flex flex-col gap-3">
            {
              links.map((link) => (
                <a class="inline-flex items-center gap-2 font-semibold text-ink-950 hover:text-steel" href={link.url}>
                  <svg class="h-4 w-4" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
                    <path d={iconPaths[link.label] ?? iconPaths.Email} />
                  </svg>
                  <span>{link.label}</span>
                </a>
              ))
            }
          </div>
        </section>
        <section class="quiet-card p-6">
          <h2 class="text-xl font-semibold text-ink-950">CV</h2>
          <ul class="mt-5 space-y-3 text-ink-650">
            <li>{profile.email}</li>
            <li>{profile.availability}</li>
            <li>
              <a class="inline-flex items-center gap-2 font-semibold text-ink-950 hover:text-steel" href={withBase(profile.cvUrl)}>
                <svg class="h-4 w-4" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
                  <path d={iconPaths.CV} />
                </svg>
                Open CV
              </a>
            </li>
          </ul>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
