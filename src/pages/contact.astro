---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import profile from "../data/profile.json";
import socialLinks from "../data/social-links.json";
import { withBase } from "../lib/paths";

const links = socialLinks;
---

<BaseLayout title={`Contact - ${profile.name}`} description="Contact links for Rafael Vera.">
  <section class="section-gap">
    <div class="container-page">
      <SectionHeading
        eyebrow="Contact"
        title="Useful links and contact details."
        description="Direct links to contact, public profiles and the current CV."
      />
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        <section class="quiet-card p-6">
          <h2 class="text-xl font-semibold text-ink-950">Profiles</h2>
          <div class="mt-5 flex flex-col gap-3">
            {links.map((link) => <a class="font-semibold text-ink-950 hover:text-steel" href={link.url}>{link.label}</a>)}
          </div>
        </section>
        <section class="quiet-card p-6">
          <h2 class="text-xl font-semibold text-ink-950">CV</h2>
          <ul class="mt-5 space-y-3 text-ink-650">
            <li>{profile.email}</li>
            <li>{profile.availability}</li>
            <li>
              <a class="font-semibold text-ink-950 hover:text-steel" href={withBase(profile.cvUrl)}>
                Open CV
              </a>
            </li>
          </ul>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
