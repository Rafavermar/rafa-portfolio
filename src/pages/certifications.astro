---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import profile from "../data/profile.json";
import { withBase } from "../lib/paths";
import { getCollection } from "astro:content";

const certifications = (await getCollection("certifications"))
  .filter((certification) => !certification.data.draft)
  .sort((a, b) => (b.data.date ?? "").localeCompare(a.data.date ?? ""));
---

<BaseLayout title={`Certifications - ${profile.name}`} description="Professional certifications and credentials.">
  <section class="section-gap">
    <div class="container-page">
      <SectionHeading
        eyebrow="Certifications"
        title="Current data platform credentials."
      />
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {
          certifications.map((certification) => (
            <a
              class="quiet-card flex min-h-48 items-center gap-6 p-6 no-underline transition hover:-translate-y-0.5 hover:border-steel"
              href={certification.data.credentialUrl}
            >
              {certification.data.image && (
                <img
                  class="h-28 w-28 shrink-0 object-contain"
                  src={withBase(certification.data.image)}
                  alt={`${certification.data.issuer} logo`}
                  loading="lazy"
                />
              )}
              <div>
                <p class="text-sm font-semibold text-steel">{certification.data.issuer}</p>
                <h2 class="mt-2 text-xl font-semibold text-ink-950">{certification.data.name}</h2>
                <div class="mt-5 flex flex-wrap gap-2">
                  {certification.data.tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
