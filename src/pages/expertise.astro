---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import profile from "../data/profile.json";
---

<BaseLayout title={`Expertise - ${profile.name}`} description="Core areas of data engineering and data architecture expertise.">
  <section class="section-gap">
    <div class="container-page">
      <SectionHeading
        eyebrow="Expertise"
        title="Where I can help"
      />
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {
          profile.expertise.map((group) => (
            <section class="quiet-card p-6">
              <h2 class="text-xl font-semibold text-ink-950">{group.title}</h2>
              <p class="mt-3 leading-7 text-ink-650">{group.summary}</p>
              <div class="mt-5 flex flex-wrap gap-2">
                {group.items.map((item) => (
                  <span class="tag">{item}</span>
                ))}
              </div>
            </section>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
