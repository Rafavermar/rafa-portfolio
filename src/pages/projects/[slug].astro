---
import BaseLayout from "../../layouts/BaseLayout.astro";
import profile from "../../data/profile.json";
import { withBase } from "../../lib/paths";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = (await getCollection("projects")).filter((project) => !project.data.draft);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const imageSrc = project.data.image?.startsWith("http")
  ? project.data.image
  : project.data.image
    ? withBase(project.data.image)
    : undefined;
---

<BaseLayout title={`${project.data.title} - ${profile.name}`} description={project.data.description}>
  <article class="section-gap">
    <div class="container-page max-w-4xl">
      <p class="eyebrow">Project</p>
      <h1 class="mt-3 text-4xl font-semibold leading-tight text-ink-950">{project.data.title}</h1>
      <p class="mt-5 text-xl leading-9 text-ink-650">{project.data.description}</p>
      {
        imageSrc && (
          <img
            class="mt-10 aspect-[16/7] w-full rounded-md border border-line bg-paper-100 object-contain p-3 shadow-soft"
            src={imageSrc}
            alt={project.data.title}
            loading="eager"
          />
        )
      }

      <dl class="mt-10 grid gap-5 sm:grid-cols-2">
        {project.data.context && <div class="quiet-card p-5"><dt class="font-semibold text-ink-950">Context</dt><dd class="mt-2 text-ink-650">{project.data.context}</dd></div>}
        {project.data.problem && <div class="quiet-card p-5"><dt class="font-semibold text-ink-950">Problem</dt><dd class="mt-2 text-ink-650">{project.data.problem}</dd></div>}
        {project.data.solution && <div class="quiet-card p-5"><dt class="font-semibold text-ink-950">Solution</dt><dd class="mt-2 text-ink-650">{project.data.solution}</dd></div>}
        {project.data.impact && <div class="quiet-card p-5"><dt class="font-semibold text-ink-950">Impact</dt><dd class="mt-2 text-ink-650">{project.data.impact}</dd></div>}
      </dl>

      {
        project.data.stack.length > 0 && (
          <section class="mt-10">
            <h2 class="text-xl font-semibold text-ink-950">Stack</h2>
            <div class="mt-4 flex flex-wrap gap-2">
              {project.data.stack.map((item) => (
                <span class="tag">{item}</span>
              ))}
            </div>
          </section>
        )
      }

      {
        project.data.links.length > 0 && (
          <section class="mt-10">
            <h2 class="text-xl font-semibold text-ink-950">Links</h2>
            <div class="mt-4 flex flex-wrap gap-4">
              {project.data.links.map((link) => (
                <a class="font-semibold text-ink-950 hover:text-steel" href={link.url}>
                  {link.label}
                </a>
              ))}
            </div>
          </section>
        )
      }

      <div class="content-body mt-10">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
