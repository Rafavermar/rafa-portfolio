---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import profile from "../data/profile.json";
import experience from "../data/experience.json";
---

<BaseLayout title={`About - ${profile.name}`} description="Professional background and working style.">
  <section class="section-gap">
    <div class="container-page">
      <SectionHeading
        eyebrow="About"
        title="Data engineering and architecture with a practical delivery mindset."
      />
      <div class="mt-10 grid gap-10 lg:grid-cols-[1fr_0.8fr]">
        <div class="space-y-5 text-lg leading-8 text-ink-650">
          {profile.about.map((paragraph) => <p>{paragraph}</p>)}
        </div>
        <aside class="quiet-card h-fit p-6">
          <h2 class="text-lg font-semibold text-ink-950">Working Principles</h2>
          <ul class="mt-5 space-y-4 text-ink-650">
            {profile.principles.map((principle) => <li>{principle}</li>)}
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <section class="section-gap soft-band">
    <div class="container-page">
      <div class="max-w-3xl">
        <p class="eyebrow">Experience</p>
        <h2 class="mt-3 text-3xl font-semibold text-ink-950">Recent roles and delivery context</h2>
      </div>
      <div class="mt-10 grid gap-5">
        {
          experience.map((item) => (
            <article class="quiet-card p-6">
              <div class="grid gap-4 md:grid-cols-[0.9fr_1.4fr]">
                <div>
                  <p class="text-sm font-semibold text-steel">{item.period}</p>
                  <h3 class="mt-2 text-xl font-semibold text-ink-950">{item.role}</h3>
                  <p class="mt-1 text-ink-650">{item.company}</p>
                  <p class="mt-1 text-sm text-ink-500">{item.location}</p>
                </div>
                <div>
                  <p class="leading-7 text-ink-650">{item.summary}</p>
                  <div class="mt-4 flex flex-wrap gap-2">
                    {item.stack.map((tool) => (
                      <span class="tag">{tool}</span>
                    ))}
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
