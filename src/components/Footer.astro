---

<footer class="border-t border-line bg-paper-100">
  <div class="container-page flex flex-col gap-6 py-10 text-sm text-ink-650 md:flex-row md:items-center md:justify-between">
    <div>
      <p class="font-semibold text-ink-950">{profile.name}</p>
      <p>Senior data engineering and architecture.</p>
    </div>
    <div class="flex flex-wrap gap-3">
      {
        visibleLinks.map((link) => (
          <a class="inline-flex items-center gap-2 hover:text-ink-950" href={link.url}>
            <svg class="h-4 w-4" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
              <path d={iconPaths[link.label] ?? iconPaths.Email} />
            </svg>
            <span>{link.label}</span>
          </a>
        ))
      }
      <a class="inline-flex items-center gap-2 hover:text-ink-950" href={withBase("/contact/")}>
        <svg class="h-4 w-4" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
          <path d={iconPaths.Email} />
        </svg>
        <span>Contact</span>
      </a>
    </div>
    <p>&copy; {year}</p>
  </div>
</footer>
