---
import { withBase } from "../lib/paths";

interface Props {
  title: string;
  description?: string;
  href?: string;
  meta?: string;
  tags?: string[];
  image?: string;
  imageAlt?: string;
  filterable?: boolean;
}

const { title, description, href, meta, tags = [], image, imageAlt, filterable = false } = Astro.props;
const Wrapper = href ? "a" : "article";
const imageSrc = image?.startsWith("http") ? image : image ? withBase(image) : undefined;
---

<Wrapper
  href={href}
  data-filter-card={filterable ? "true" : undefined}
  data-tags={filterable ? tags.join("|") : undefined}
  class:list={[
    "quiet-card block p-6 no-underline transition",
    href && "hover:-translate-y-0.5 hover:border-steel hover:shadow-soft",
  ]}
>
  {
    imageSrc && (
      <img
        class="-mx-6 -mt-6 mb-5 h-44 w-[calc(100%+3rem)] border-b border-line bg-paper-100 object-contain p-2"
        src={imageSrc}
        alt={imageAlt ?? ""}
        loading="lazy"
      />
    )
  }
  <div class="flex h-full flex-col">
    {meta && <p class="text-sm font-medium text-steel">{meta}</p>}
    <h2 class="mt-3 text-xl font-semibold text-ink-950">{title}</h2>
    {description && <p class="mt-3 line-clamp-3 leading-7 text-ink-650">{description}</p>}
    {
      tags.length > 0 && (
        <div class="mt-5 flex flex-wrap gap-2">
          {tags.slice(0, 4).map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )
    }
  </div>
</Wrapper>
