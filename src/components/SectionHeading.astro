---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="max-w-3xl">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h1 class="mt-3 text-3xl font-semibold tracking-normal text-ink-950 sm:text-4xl">{title}</h1>
  {description && <p class="mt-4 text-lg leading-8 text-ink-650">{description}</p>}
</div>

